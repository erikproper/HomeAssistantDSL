    entity sensor.infrastructural:frame:temperature no_collect with:
      definition cli_sensor pi 192.168.178.58 ./cpu/temperature;
    end;

    entity cover.social:front with:
      open_stop_close;
      providing node front/somfy;
    end;
    entity number.social:front:my_position;
    entity button.social:front:to_my_position;
    entity button.infrastructural:front/somfy:identify;

    entity cover.social:rear with:
      open_stop_close;
      providing node rear/somfy;
    end;
    entity number.social:rear:my_position;
    entity button.social:rear:to_my_position;
    entity button.infrastructural:rear/somfy:identify;

    thermostat front/radiator/aqara_thermostat;
    battery_level front/radiator/aqara_thermostat 20;

    thermostat rear/radiator/aqara_thermostat;
    battery_level rear/radiator/aqara_thermostat 20;

    entity sensor.physical:netatmo:co2;
    entity sensor.physical:netatmo:humidity;
    entity sensor.physical:netatmo:noise;
    entity sensor.physical:netatmo:pressure;
    entity sensor.physical:netatmo:temperature;
    entity sensor.infrastructural:netatmo:radio;
    entity sensor.infrastructural:netatmo:reachability;
    entity binary_sensor.infrastructural:netatmo:node with:
      condition sensor.infrastructural:netatmo:reachability "$ == 'True'";
    end;

    battery_level_device dining/philips_dimmer with:
      alert_level 20;
    end;
    battery_level_device living/philips_dimmer with:
      alert_level 20;
    end;

    light_device social:indirect;

    space social:living with:
      entity light.physical:main no_collect with:
        providing node hallway_door_switch_box/fibaro;
      end;
      entity light.physical:main_dimmer no_collect;
      entity light.social:main with:
