        threshold 10;
      end;
      power_switch switch.social:drying with:
        node robb/drying;
        threshold 10;
      end;
    end;

    space social:water_pump with:
      entity binary_sensor.physical:aqara_water:water;
      battery_level_device aqara_water;
    end;

    light on: social:main;
    lights_motion_guarded with delay 10;
    space off: @light;
  end;

  space social:living_room with:
    entity switch.social:tv with:
      providing node tv_switch;
    end;

    media_player sonos no_play "TV";
