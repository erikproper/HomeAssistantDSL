      end;

      light on: social:main;
    end;

    space social:dining with:
      entity light.physical:main no_collect;
      entity light.physical:main_dimmer no_collect;
      entity light.social:main with:
        icon mdi:lightbulb;
        definition switched_device light.physical:main_dimmer light.physical:main;
      end;

      entity light.social:red_highboard;

      entity binary_sensor.physical:windows/aqara_magnet:window;
      battery_level_device windows/aqara_magnet with:
        alert_level 10;
      end;

      light on: social:main;
    end;

    heating leak binary_sensor.social::window;

    light on: social:dining;

