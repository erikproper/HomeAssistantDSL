# This file keeps the legacy entity structure, but normalizes blocks using with:/end; and statement ';'.

entity sensor.social:power_total;
# Availability depends on binary_sensor.infrastructural:smarty:node
entity sensor.social:power_current;
# Availability depends on binary_sensor.infrastructural:smarty:node

space social:entrance with:
  entity sensor._:/ems_esp_boiler_boiler_outside_temperature;
  entity sensor.physical:garage_door:temperature with:
    value sensor._:/ems_esp_boiler_boiler_outside_temperature;
  end;
  # Available if binary_sensor.infrastructural:/house/laundry_kitchen/ems:node is available.

  entity switch.social:sockets with:
    providing node /garage/fuse_box/zwave/028;
  end;
  entity light.social:front_door;
  entity light.social:carport with:
    providing node /house/server_room/zwave/027;
  end;

  entity binary_sensor.social:front_door:ding with:
    providing node ring;
  end;
  entity binary_sensor.social:front_door:motion;
  entity sensor.social:front_door/ring:volume;
  entity sensor.infrastructural:front_door/ring:battery_level;
  battery_alert front_door/ring with:
    alert_level 20;
  end;

  light on: social:front_door;
  space off: @light;
end;

space social:terrace with:
  space social:front with:
    entity sensor.physical:netatmo:humidity;
    entity sensor.physical:netatmo:temperature;
    entity sensor.infrastructural:netatmo:radio;
    entity sensor.infrastructural:netatmo:reachability;
    entity binary_sensor.infrastructural:netatmo:node with:
      condition sensor.infrastructural:netatmo:reachability "$ == 'True'";
    end;
    entity sensor.infrastructural:netatmo:battery_level;
    battery_alert netatmo with:
      alert_level 20;
    end;

    entity light.social:main with:
      providing node /house/server_room/fuse_box/zwave/024;
    end;

    space off: @light;
  end;

  space social:garden with:
    entity sensor.physical:aqara_multi:humidity;
    entity sensor.physical:aqara_multi:pressure;
    entity sensor.physical:aqara_multi:temperature;
    battery_level_device aqara_multi with:
      alert_level 15;
    end;

    entity light.social:main with:
      providing node /house/server_room/fuse_box/zwave/027;
    end;

    space off: @light;
  end;

  entity cover.social:awnings with:
    open_stop_close;
    no_collect;
    providing node /house/server_room/fuse_box/zwave/013;
  end;

  entity light.social:rear;

  entity switch.social:sockets with:
    providing node /house/server_room/fuse_box/zwave/025;
  end;

  light on: social:rear;
  space off: switch.social:sockets @light;
end;

space social:garage with:
  entity binary_sensor.infrastructural:smarty:node;
  entity sensor.infrastructural:smarty:load with:
    definition cli_sensor pi smarty.fritz.box ./cpu/load;
    # Availability depends on binary_sensor.infrastructural:smarty:node
  end;
  entity sensor.infrastructural:smarty:temperature no_collect with:
    definition cli_sensor pi smarty.fritz.box ./cpu/temperature;
    # Availability depends on binary_sensor.infrastructural:smarty:node
  end;
  entity switch.infrastructural:smarty with:
    providing node smarty/innr;
  end;

  entity sensor.physical:rear/aqara_multi:humidity;
  entity sensor.physical:rear/aqara_multi:pressure with:
    adjustment 38 1;
  end;
  entity sensor.physical:rear/aqara_multi:temperature;
  battery_level_device rear/aqara_multi with:
    alert_level 15;
  end;

  entity binary_sensor.physical:rear/ikea_motion:motion with:
    providing node rear/ikea_motion;
  end;
  entity sensor.infrastructural:rear/ikea_motion:battery_level;
  battery_alert rear/ikea_motion with:
    alert_level 10;
  end;

  entity sensor.physical:front/aqara_multi:humidity;
  entity sensor.physical:front/aqara_multi:pressure with:
    adjustment 38 1;
  end;
  entity sensor.physical:front/aqara_multi:temperature;
  battery_level_device front/aqara_multi with:
    alert_level 15;
  end;

  entity binary_sensor.physical:front/ikea_motion:motion with:
    providing node front/ikea_motion;
  end;
  entity sensor.infrastructural:front/ikea_motion:battery_level;
  battery_alert front/ikea_motion with:
    alert_level 10;
  end;

  entity binary_sensor.physical:garage_door/aqara_magnet:door;
  battery_level_device garage_door/aqara_magnet with:
    alert_level 10;
  end;

  entity light.social:main with:
    providing node /garage/fuse_box/zwave/019;
  end;

  media_player sonos;

  thermostat radiator/aqara_thermostat;
  battery_level radiator/aqara_thermostat 20;

  heating leak binary_sensor.social:door;

  light on: social:main;
  lights_motion_guarded with delay 10;
  space off: @light @media;
end;

space social:house with:
  entity sensor.social:heating:power;

  power_switch switch.social:rainwater_pump with:
    node zigbee;
    threshold 10;
  end;

  entity binary_sensor.social:reservoir:warning with:
    icon $WaterIcon;
  end;

