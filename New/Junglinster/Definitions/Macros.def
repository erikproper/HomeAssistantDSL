# Source: Old/Junglinster/Macros

# Macros are collapsed into one file, but still form a prelude that should be read before other definitions.

creation macro battery_alert { $alertLevel int op }:
  # Source: entity_battery_alert.def
  if $alertLevel is provided then
    entity binary_sensor.infrastructural:$entity:battery_alert with:
      definition as condition sensor.infrastructural:$entity:battery_level "($ | int(0)) < $alertLevel";
      available always;
    end;
  else
    entity binary_sensor.infrastructural:$entity:battery_alert;
end;

creation macro battery_from_device { $sourceEntity entityReference, $alertLevel int op }:
  # Source: entity_battery_from_device.def
  entity sensor.infrastructural:$entity:battery_level with definition as value $sourceEntity!battery_level;

  entity battery_alert $entity $alertLevel;
end;

creation macro battery_level { $alertLevel int op }:
  # Source: entity_battery_level.def
  entity battery_alert $entity $alertLevel;

  entity sensor.infrastructural:$entity:battery_level;
end;

creation macro battery_level_device { $alertLevel int op }:
  # Source: entity_battery_level_device.def
  entity battery_level $entity $alertLevel with providing node $entity;
end;

creation macro light_device:
  entity light.$sphere:$entity with providing node $entity/light;
end;

creation macro media_player { $enabler string op, $delayOff string op, $no_play_input string op, $no_collect option}:
  $mediaPlayer = entity media_player.social:$entity with:
    maybe apply no_collect;
    if $enabler is provided then
      providing node $entity $enabler $delayOff;
  end;

  entity switch.social:$mediaPlayer:media with:
    if $no_play_input is provided then
      definition as media_switch $mediaPlayer $no_play_input;

    maybe apply no_collect;
    icon $MediaSwitchIcon;
  end;
end;

creation macro power_switch { $node string, $threshold int }:
  # Source: entity_power_switch.def
  entity sensor.$sphere:$entity:power;

  entity binary_sensor.$sphere:$entity:consumes with:
    definition as condition sensor.$sphere:$entity:power "($ | int(0)) > $threshold";

    icon as provided or default $ConsumesIcon;
  end;

  entity switch.$sphere::$entity with providing node $entity/$node;
end;

creation macro switch_device { $name string op }:
  entity switch.$sphere:$entity with providing node $entity/switch;
end;

creation macro thermostat:
  # Source: entity_thermostat.def
  entity climate.physical:$entity with providing node $entity;

  entity sensor.physical:$entity:temperature with definition as value climate.physical:$entity!current_temperature;
end;

creation macro zigbee_group { $group set of string }:
  # Source: entity_zigbee_group.def
  # $1 = Domain, $2 = Sphere, $3 = Location, $4 ... $n = Entity names
  create <$type>_device $sphere:$entity;

  space physical:$entity with:
    no_collect;

    for $element in $group do
      create <$type>_device physical:$element;
  end;
end;

creation macro zwave_node:
  # Source: entity_zwave_node.def
  entity sensor.infrastructural:$entity/status;

  entity binary_sensor.infrastructural:$entity:node with definition as condition sensor.infrastructural:$entity/status "($ == 'alive')";
end;

creation macro windy { $delayOn string, $delayOff string }:
  # Windy condition: compares wind speed threshold against a sensor value.
  # Multi-parameter condition syntax: $1 is threshold, $2 is sensor value.
  $windyThreshold = entity input_number.social:/:windy_threshold with:
    definition as input_number;
    minimum $WindSpeedMin;
    maximum $WindSpeedMax;
    icon $WindSpeedIcon;
    units $WindSpeedUnit;
  end;

  entity binary_sensor.social::windy with:
    definition as condition $windyThreshold $entity "($1 | int) > ($2 | int)";
    device_class $WindyDeviceClass;
    delay_on $delayOn;
    delay_off $delayOff;
  end;
end;

creation macro sunny { $delayOn string, $delayOff string }:
  # Sunny condition: compares illuminance threshold against a sensor value.
  # Multi-parameter condition syntax: $1 is threshold, $2 is sensor value.
  $sunnyThreshold = entity input_number.social:/:sunny_threshold with:
    definition as input_number;
    minimum $IlluminanceMin;
    maximum $IlluminanceMax;
    icon $IlluminanceIcon;
    units $IlluminanceUnit;
  end;

  entity binary_sensor.social::sunny with:
    definition as condition $sunnyThreshold $entity "($1 | int) < ($2 | int)";
    device_class $SunnyDeviceClass;
    delay_on $delayOn;
    delay_off $delayOff;
  end;
end;
