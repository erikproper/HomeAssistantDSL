space social:apartment with:
  space social:hallway with:
    entity binary_sensor.social:door;
    #entity binary_sensor.physical:door;
    call battery_level_device :aqara_windoor with alert_level 10;

    entity sensor.physical:door/aqara_multi/temperature;
    entity sensor.physical:door/aqara_multi/pressure with adjustment 20 1;
    entity sensor.physical:door/aqara_multi/humidity;
    call battery_level_device :door/aqara_multi with alert_level 15;

    entity sensor.physical:frient/illuminance;
    entity sensor.physical:frient/temperature;
    entity binary_sensor.physical:frient/motion;
    call battery_level_device :frient;

    call device light.social:main;

    call battery_level_device :bedroom/door/moes with alert_level 20;
    call battery_level_device :door/moes with alert_level 20;

    light on: social:main;
    light off: social:main;
  end;

  space social:living_room with:
    entity sensor.physical:netatmo/co2 with:
      imported rest junglinster sensor.physical_vienna_living_room_co2 60;
    end;
    entity sensor.physical:netatmo/humidity with:
      imported rest junglinster sensor.physical_vienna_living_room_humidity 60;
    end;
    entity sensor.physical:netatmo/noise with:
      imported rest junglinster sensor.physical_vienna_living_room_noise 60;
    end;
    entity sensor.physical:netatmo/pressure with:
      imported rest junglinster sensor.physical_vienna_living_room_pressure 60;
    end;
    entity sensor.physical:netatmo/temperature with:
      imported rest junglinster sensor.physical_vienna_living_room_temperature 60;
    end;
    entity sensor.infrastructural:netatmo/radio with:
      imported rest junglinster sensor.infrastructural_vienna_living_room_netatmo_radio 60;
    end;
    entity binary_sensor.infrastructural:netatmo/node with:
      imported rest junglinster sensor.infrastructural_vienna_living_room_netatmo_reachability 60 "$ == 'True'";
    end;

    entity switch.social:picture_frame with:
      cli_switch pi frame.fritz.box ./bin/start_slideshow ./bin/stop_slideshow ./bin/check_slideshow;
    end;

    entity sensor.physical:philips_motion/illuminance;
    entity sensor.physical:philips_motion/temperature;
    entity binary_sensor.physical:philips_motion/motion;
    call battery_level_device :philips_motion with alert_level 10;

    call battery_level_device :signify_dimmer with alert_level 20;

    entity vacuum.social with call providing :roborock;
    entity sensor.infrastructural:roborock/battery_level;
    call battery_alert :roborock with alert_level 15;

    call thermostat :bitron_thermostat;
    call battery_level :bitron_thermostat;

    entity sensor.infrastructural:fritz_box_7590_ax_gb_received with call providing :fritz_box;
    entity sensor.infrastructural:fritz_box_7590_ax_gb_sent;

    entity switch.social:desktop with:
      icon ${desktop_icon};
      call providing :desktop;
    end;

    entity switch.social:tv with call providing :tv_switch;

    call media_player_device :sonos;
    call media_player_device :apple_tv;
    call media_player_device :tv with:
      enabler switch.social:tv;
      delay_off 00:01:00;
    end;

    entity binary_sensor.social:living/door;
    call battery_level_device :living/aqara_windoor with alert_level 10;

    call zigbee_group light.social:main with group { kitchen, middle, living };

    space social:vidja with:
      call zigbee_group light.social:left with group { 1, 2, 3, 4, 5, 6 };
      call zigbee_group light.social:right with group { 1, 2, 3, 4, 5, 6 };
    end;

    space social:kitchen with:
      entity binary_sensor.social:terrace/door;
      call battery_level_device :aqara_windoor with alert_level 10;

      entity switch.social:nespresso;

      entity binary_sensor.physical:aqara_water/water;
      call battery_level_device :aqara_water;

      entity binary_sensor.social:fridge/door with icon ${fridge_door_icon};
      call battery_level_device :fridge/aqara_windoor with alert_level 10;

      entity sensor.physical:dishwasher/robb/temperature no_collect;
      call power_switch switch.social:dishwasher with:
        node robb;
        threshold 1;
        icon ${dishwasher_icon};
      end;

      call device light.social:workplace;

      entity cover.social with:
        open_stop_close;
        call providing :blinds;
      end;

      space off: switch.social:nespresso;
    end;

    entity cover.social:living with:
      open_stop_close;
      call providing :blinds;
    end;

    space social:rack with:
      entity sensor.physical:aqara_multi/temperature;
      entity sensor.physical:aqara_multi/pressure with adjustment 20 1;
      entity sensor.physical:aqara_multi/humidity;
      call battery_level_device :aqara_multi with alert_level 15;

      entity binary_sensor.infrastructural:frame/node;
      entity sensor.infrastructural:frame/load with:
        cli_sensor pi frame.fritz.box ./cpu/load;
      end;
      entity sensor.infrastructural:frame/temperature no_collect with:
        cli_sensor pi frame.fritz.box ./cpu/temperature;
      end;

      entity sensor.infrastructural:vienna/load;
      entity sensor.infrastructural:vienna/temperature no_collect;
    end;

    call battery_level_device :hallway_door/moes/1 with alert_level 20;
    call battery_level_device :hallway_door/moes/2 with alert_level 20;
    call battery_level_device :hallway_door/moes/3 with alert_level 20;
    call battery_level_device :hallway_door/moes/4 with alert_level 20;

    call battery_level_device :kitchen/door/moes/1 with alert_level 20;
    call battery_level_device :kitchen/door/moes/2 with alert_level 20;

    call battery_level_device :living/door/moes/1 with alert_level 20;
    call battery_level_device :living/door/moes/2 with alert_level 20;

    entity input_number.social:temperature_desired with:
      minimum 10;
      maximum 30;
      step 1;
      icon "${temperature_icon}";
      unit "°C";
    end;
    entity input_number.social:heating_target_preset_for_around with:
      minimum 10;
      maximum 30;
      step 1;
      icon "${temperature_icon}";
      unit "°C";
    end;
    entity input_number.social:heating_target_preset_for_away with:
      minimum 10;
      maximum 30;
      step 1;
      icon "${temperature_icon}";
      unit "°C";
    end;
    entity input_number.social:heating_target_preset_for_day with:
      minimum 10;
      maximum 30;
      step 1;
      icon "${temperature_icon}";
      unit "°C";
    end;
    entity input_number.social:heating_target_preset_for_night with:
      minimum 10;
      maximum 30;
      step 1;
      icon "${temperature_icon}";
      unit "°C";
    end;
    entity input_number.social:heating_target_preset_for_leakage with:
      minimum 10;
      maximum 30;
      step 1;
      icon "${temperature_icon}";
      unit "°C";
    end;

    heating leak: binary_sensor.social:living/door;
    heating leak: binary_sensor.social:kitchen/terrace/door;
    heating leak: binary_sensor.social/apartment/bedroom/door;
    heating leak: binary_sensor.social/apartment/hallway/door;

    light on: social:main;
    space off: switch.social:picture_frame;
    space off: switch.social:tv;
  end;

  space social:bedroom with:
    entity sensor.infrastructural:netatmo/battery_level with:
      imported rest junglinster sensor.infrastructural_vienna_bedroom_netatmo_battery_level 60;
    end;
    call battery_alert :netatmo with alert_level 20;
    entity sensor.physical:co2 with:
      imported rest junglinster sensor.physical_vienna_bedroom_co2 60;
    end;
    entity sensor.physical:humidity with:
      imported rest junglinster sensor.physical_vienna_bedroom_humidity 60;
    end;
    entity sensor.physical:netatmo/temperature with:
      imported rest junglinster sensor.physical_vienna_bedroom_temperature 60;
    end;
    entity sensor.infrastructural:netatmo/radio with:
      imported rest junglinster sensor.infrastructural_vienna_bedroom_netatmo_radio 60;
    end;
    entity binary_sensor.infrastructural:netatmo/node with:
      imported rest junglinster sensor.infrastructural_vienna_bedroom_netatmo_reachability 60 "$ == 'True'";
    end;

    entity sensor.physical:frient/illuminance;
    entity sensor.physical:frient/temperature;
    entity binary_sensor.physical:frient/motion;
    call battery_level_device :frient;

    call battery_level_device :bed/moes with alert_level 20;
    call battery_level_device :bed/shortcut/left with alert_level 20;
    call battery_level_device :bed/shortcut/right with alert_level 20;
    call battery_level_device :door/moes/1 with alert_level 20;
    call battery_level_device :door/moes/2 with alert_level 20;
    call battery_level_device :hallway/door/moes/1 with alert_level 20;
    call battery_level_device :hallway/door/moes/2 with alert_level 20;

    entity binary_sensor.physical:door;
    call battery_level_device :aqara_windoor with alert_level 10;

    space social:bed with:
      call device light.social:left;
      call device light.social:right;
    end;
    call device light.social:main;

    call media_player_device :sonos;
    entity sensor.infrastructural:sonos/battery_level;
    call battery_alert :sonos with alert_level 10;

    entity cover.social with:
      open_stop_close;
      call providing :blinds;
    end;

    light on: social:main;
  end;

  space social:shower_room with:
    entity sensor.infrastructural:netatmo/battery_level with:
      imported rest junglinster sensor.infrastructural_vienna_shower_room_netatmo_battery_level 60;
    end;
    call battery_alert :netatmo with alert_level 20;
    entity sensor.physical:netatmo/co2 with:
      imported rest junglinster sensor.physical_vienna_shower_room_netatmo_co2 60;
    end;
    entity sensor.physical:netatmo/humidity with:
      imported rest junglinster sensor.physical_vienna_shower_room_netatmo_humidity 60;
    end;
    entity sensor.physical:netatmo/temperature with:
      imported rest junglinster sensor.physical_vienna_shower_room_netatmo_temperature 60;
    end;
    entity sensor.infrastructural:netatmo/radio with:
      imported rest junglinster sensor.infrastructural_vienna_shower_room_netatmo_radio 60;
    end;
    entity binary_sensor.infrastructural:netatmo/node with:
      imported rest junglinster sensor.infrastructural_vienna_shower_room_netatmo_reachability 60 "$ == 'True'";
    end;

    entity sensor.physical:philips_motion/illuminance;
    entity sensor.physical:philips_motion/temperature;
    entity binary_sensor.physical:philips_motion/motion;
    call battery_level_device :philips_motion with alert_level 10;

    entity binary_sensor.physical:aqara_water/water;
    call battery_level_device :aqara_water;

    entity sensor.physical:radiator/robb/temperature no_collect;
    call power_switch switch.social:radiator with:
      node robb;
      threshold 1;
      icon ${radiator_icon};
    end;

    entity sensor.physical:washing_machine/robb/temperature no_collect;
    call power_switch switch.social:washing_machine with:
      node robb;
      threshold 1;
      icon ${washing_machine_icon};
    end;

    call device light.social:main;
    call device light.social:mirror;

    call battery_level_device :door/moes/1 with alert_level 20;
    call battery_level_device :door/moes/2 with alert_level 20;
    call battery_level_device :mirror/moes with alert_level 20;

    light on: social:main;
    lights_motion_guarded with delay 15;
  end;

  light on: social:living_room social:hallway;
end;

space social:terrace with:
  entity sensor.infrastructural:netatmo_outdoor/battery_level with:
    imported rest junglinster sensor.infrastructural_vienna_terrace_netatmo_outdoor_battery_level 60;
  end;
  call battery_alert :netatmo_outdoor with alert_level 20;
  entity sensor.physical:netatmo_outdoor/humidity with:
    imported rest junglinster sensor.physical_vienna_terrace_netatmo_outdoor_humidity 60;
  end;
  entity sensor.physical:netatmo_outdoor/temperature with:
    imported rest junglinster sensor.physical_vienna_terrace_netatmo_outdoor_temperature 60;
  end;
  entity sensor.infrastructural:netatmo_outdoor/radio with:
    imported rest junglinster sensor.infrastructural_vienna_terrace_netatmo_outdoor_radio 60;
  end;
  entity binary_sensor.infrastructural:netatmo_outdoor/node with:
    imported rest junglinster sensor.infrastructural_vienna_terrace_netatmo_outdoor_reachability 60 "$ == 'True'";
  end;

  entity sensor.infrastructural:netatmo_windmeter/battery_level with:
    imported rest junglinster sensor.infrastructural_vienna_terrace_netatmo_windmeter_battery_level 60;
  end;
  call battery_alert :netatmo_windmeter with alert_level 20;
  entity sensor.social:wind_direction with:
    imported rest junglinster sensor.physical_vienna_terrace_netatmo_windmeter_wind_direction 60;
  end;
  entity sensor.social:wind_speed with:
    imported rest junglinster sensor.physical_vienna_terrace_netatmo_windmeter_wind_speed 60;
  end;
  entity sensor.infrastructural:netatmo_windmeter/radio with:
    imported rest junglinster sensor.infrastructural_vienna_terrace_netatmo_windmeter_radio 60;
  end;
  entity binary_sensor.infrastructural:netatmo_windmeter/node with:
    imported rest junglinster sensor.infrastructural_vienna_terrace_netatmo_windmeter_reachability 60 "$ == 'True'";
  end;

  call windy sensor.social:wind_speed 00:01:00 00:10:00;

  entity binary_sensor.social:daylight with condition sun.[sun]!elevation "$ > 4";

  call device light.physical:left;
  call device light.physical:right;

  entity sensor.physical:signify_motion/illuminance with call providing :signify_motion;
  entity sensor.physical:signify_motion/temperature;
  entity binary_sensor.physical:signify_motion/motion;
  entity sensor.infrastructural:signify_motion/battery_level;
  call battery_alert :signify_motion with alert_level 20;
  call sunny sensor.physical:signify_motion/illuminance 00:05:00 00:05:00;
end;

light on: social;

entity sun.[sun];

entity input_boolean.social/occupation/home with icon "${home_icon}";
entity input_boolean.social/occupation/around with icon "${around_icon}";
entity input_boolean.social/occupation/away with icon "${away_icon}";
entity input_boolean.social/covers/auto_control with icon "${covers_auto_control_icon}";
entity input_boolean.social/vacuum_should_be_active with icon "${vacuum_icon}";
entity input_boolean.social/vacuuming_requested with icon "${vacuum_icon}";
entity input_boolean.social/apartment/living_room/heating/enable with icon "${heating_icon}";
entity input_boolean.social/apartment/living_room/heating/leakage/ignore with icon "${heating_icon}";
entity input_boolean.social/apartment/shower_room/no_motion/ignore with icon "${ignore_no_motion_icon}";

entity input_datetime.social/coverage_workday/start_day with:
  has_time;
end;
entity input_datetime.social/coverage_workday/start_night with:
  has_time;
end;
entity input_datetime.social/coverage_holiday/start_day with:
  has_time;
end;
entity input_datetime.social/coverage_holiday/start_night with:
  has_time;
end;
entity input_datetime.social/heating_workday/start_day with:
  has_time;
end;
entity input_datetime.social/heating_workday/start_night with:
  has_time;
end;
entity input_datetime.social/heating_holiday/start_day with:
  has_time;
end;
entity input_datetime.social/heating_holiday/start_night with:
  has_time;
end;
entity input_datetime.social/vacuuming_workday/start_day with:
  has_time;
end;
entity input_datetime.social/vacuuming_workday/start_night with:
  has_time;
end;
entity input_datetime.social/vacuuming_holiday/start_day with:
  has_time;
end;
entity input_datetime.social/vacuuming_holiday/start_night with:
  has_time;
end;
