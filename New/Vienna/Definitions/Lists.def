list "Nodes" all binary_sensor.*:*:node with:
  clean_prefix  infrastructural;
  clean_postfix node;
  clean_prefix  apartment;
end;

list "Windoors" all binary_sensor.*:*:door binary_sensor.*:*:window with:
  clean_prefix  social;
  clean_prefix  physical;
  clean_prefix  apartment;
end;

list "Water" all binary_sensor.*:*:water with:
  clean_prefix  social;
  clean_prefix  physical;
  clean_prefix  apartment;
end;

list "Battery levels" all sensor.*:*:battery_level with:
  clean_prefix  infrastructural;
  clean_postfix battery_level;
end;

list "Battery alerts" all binary_sensor.*:*:battery_alert with:
  clean_prefix  infrastructural;
  clean_postfix battery_alert;
end;

list "Radios" all sensor.*:*:radio with:
  clean_prefix  infrastructural;
  clean_postfix radio;
end;

list "Temperatures" all sensor.*:*:temperature with:
  clean_prefix  social;
  clean_prefix  physical;
  clean_prefix  infrastructural;
  clean_prefix  apartment;
end;

list "Thermostats" all climate.* with:
  clean_prefix  social;
  clean_prefix  physical;
  clean_prefix  apartment;
  clean_postfix thermostat;
end;

list "Covers" all cover.* with:
  clean_prefix  social;
  clean_prefix  physical;
  clean_prefix  apartment;
end;

list "Ignore no motion" all input_boolean.*:*:no_motion/ignore with:
  clean_prefix  social;
  clean_postfix no_motion.ignore;
end;

list "Ignore leakage" all input_boolean.*:*:heating/leakage/ignore with:
  clean_prefix  social;
  clean_postfix heating.leakage.ignore;
end;
