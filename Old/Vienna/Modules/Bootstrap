###
#
# Bootstraping ... basic functions, global variables, reading modules, definitions, etc.
#
###

function TryReadFile { # $1 = File
  if [ -f "$1" ]; then
    source "$1"
  fi
}

function ListFolder { # $1 = Folder
  for f in "$1"/*; do
    if [ -e "$f" ]; then
      echo $f
    fi
  done
}

function ReportFileName { # $1 = File path 
  echo "- $(basename $1)"
}

function ReadModules {
  for m in $(ListFolder $Modules); do
    ReportFileName $m
    TryReadFile $m
  done
}

function ReadSettings {
  for s in $(ListFolder $Settings); do
    ReportFileName $s
    TryReadFile $s
  done
}

function ServerIsUp {
  if [ "$1" == "" ]; then
    false
  else
    UP="$(ping -c 2 -t 1 $1 2> /dev/null | grep "bytes from" | wc -l)"
    [ $UP -gt 0 ]
  fi
}

function ReadDefinitions {
  EntityCount=0

  begin_space
    entity declare input_boolean.infrastructural::dummy
      InputBooleanDefinition off
    DummySwitchableReference=$EntityReference
    DummySwitchable=$HASSFullName
    DummyTurnOnService=$Domain.turn_on
    DummyTurnOffService=$Domain.turn_off

    entity declare binary_sensor.infrastructural::on
      define constant on
    BinarySensorOnReference=$EntityReference
    BinarySensorOn=$HASSFullName

    entity declare binary_sensor.infrastructural::off
      define constant off
    BinarySensorOffReference=$EntityReference
    BinarySensorOff=$HASSFullName

    entity declare binary_sensor.social:workday
      icon $WorkdayIcon
    IsWorkday=$HASSFullName

    for d in $(ListFolder $Definitions); do
      if [ -f "$d" ]; then
        ReportFileName $d
        TryReadFile $d
      fi
    done
  end_space

  DefineGlobals
}

function ReadMacros {
  for m in $(ListFolder $Macros); do
    if [ -f "$m" ]; then
      ReportFileName $m
      TryReadFile $m
    fi
  done
}

