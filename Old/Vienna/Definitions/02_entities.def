begin space social:apartment
  begin space social:hallway
    entity declare binary_sensor.physical::door
    entity battery_level_device aqara_windoor 10

    entity declare sensor.physical:door/aqara_multi:temperature
    entity declare sensor.physical:door/aqara_multi:pressure
      define adjust 20 1
    entity declare sensor.physical:door/aqara_multi:humidity
    entity battery_level_device door/aqara_multi 15

    entity declare sensor.physical:frient:illuminance
    entity declare sensor.physical:frient:temperature
    entity declare binary_sensor.physical:frient:motion
    entity battery_level_device frient

    entity light_device main

    entity battery_level_device bedroom/door/moes 20
    entity battery_level_device door/moes 20
  end space
  
  begin space social:living_room
    entity declare sensor.physical:netatmo:co2
      import rest junglinster sensor.physical_vienna_living_room_co2 60
    entity declare sensor.physical:netatmo:humidity
      import rest junglinster sensor.physical_vienna_living_room_humidity 60
    entity declare sensor.physical:netatmo:noise
      import rest junglinster sensor.physical_vienna_living_room_noise 60
    entity declare sensor.physical:netatmo:pressure
      import rest junglinster sensor.physical_vienna_living_room_pressure 60
    entity declare sensor.physical:netatmo:temperature
      import rest junglinster sensor.physical_vienna_living_room_temperature 60
    entity declare sensor.infrastructural:netatmo:radio
      import rest junglinster sensor.infrastructural_vienna_living_room_netatmo_radio 60
    entity declare binary_sensor.infrastructural:netatmo:node
      import rest junglinster sensor.infrastructural_vienna_living_room_netatmo_reachability 60 "$ == 'True'"

    entity declare switch.social:picture_frame
      define cli_switch pi frame.fritz.box ./bin/start_slideshow ./bin/stop_slideshow ./bin/check_slideshow

    entity declare sensor.physical:philips_motion:illuminance
    entity declare sensor.physical:philips_motion:temperature
    entity declare binary_sensor.physical:philips_motion:motion
    entity battery_level_device philips_motion 10
    
    entity battery_level_device signify_dimmer 20

    entity declare vacuum.social::
      provides device_node roborock
    entity declare sensor.infrastructural:roborock:battery_level
    entity battery_alert roborock 15

    entity thermostat bitron_thermostat
    entity battery_level bitron_thermostat

    heating_leak binary_sensor.social:living:door
    heating_leak binary_sensor.social:kitchen:door
    heating_leak binary_sensor.social:/apartment/bedroom:door
    heating_leak binary_sensor.social:/apartment/hallway:door

    entity declare sensor.infrastructural:fritz_box_7590_ax_gb_received
      provides device_node fritz_box
    entity declare sensor.infrastructural:fritz_box_7590_ax_gb_sent

    entity declare switch.social::desktop
      icon mdi:desktop-classic
      provides device_node desktop

    entity declare switch.social:tv
      provides device_node tv_switch

    entity media_player sonos
    entity media_player apple_tv
    entity media_player tv switch.social:tv 00:01:00
    
    entity declare binary_sensor.social:living:door
    entity battery_level_device living/aqara_windoor 10

    entity zigbee_group light social main kitchen middle living
    
    begin space social:vidja
      entity zigbee_group light social left  1 2 3 4 5 6
      entity zigbee_group light social right 1 2 3 4 5 6
    end space
      
    begin space social:kitchen
      entity declare binary_sensor.social:terrace:door
      entity battery_level_device aqara_windoor 10

      entity declare switch.social:nespresso

      entity declare binary_sensor.physical:aqara_water:water
      entity battery_level_device aqara_water

      entity declare binary_sensor.social:fridge:door
        icon mdi:fridge-variant-alert
      entity battery_level_device fridge/aqara_windoor 10

      entity declare sensor.physical:dishwasher/robb:temperature no_collect
      entity power_switch social dishwasher robb 1
        icon mdi:dishwasher

      entity light_device social workplace

      entity declare cover.social::
        open_stop_close
        provides device_node blinds

       space_off switch.social:nespresso
    end space

    entity declare cover.social:living:
      open_stop_close
      provides device_node blinds
    
    begin space social:rack
      entity declare sensor.physical:aqara_multi:temperature
      entity declare sensor.physical:aqara_multi:pressure
        define adjust 20 1
      entity declare sensor.physical:aqara_multi:humidity
      entity battery_level_device aqara_multi 15

      entity declare binary_sensor.infrastructural:frame:node
      entity declare sensor.infrastructural:frame:load
        define cli_sensor pi frame.fritz.box ./cpu/load
      entity declare sensor.infrastructural:frame:temperature no_collect
        define cli_sensor pi frame.fritz.box ./cpu/temperature

      entity declare sensor.infrastructural:vienna:load
      entity declare sensor.infrastructural:vienna:temperature no_collect
    end space

    entity battery_level_device hallway_door/moes/1 20
    entity battery_level_device hallway_door/moes/2 20
    entity battery_level_device hallway_door/moes/3 20
    entity battery_level_device hallway_door/moes/4 20

    entity battery_level_device kitchen/door/moes/1 20
    entity battery_level_device kitchen/door/moes/2 20

    entity battery_level_device living/door/moes/1 20
    entity battery_level_device living/door/moes/2 20

    light_on social:main
    space_off switch.social:picture_frame
    space_off switch.social:tv
  end space 
  
  begin space social:bedroom
    entity declare sensor.infrastructural:netatmo:battery_level
      import rest junglinster sensor.infrastructural_vienna_bedroom_netatmo_battery_level 60
    entity battery_alert netatmo 20
    entity declare sensor.physical::co2
      import rest junglinster sensor.physical_vienna_bedroom_co2 60
    entity declare sensor.physical::humidity
      import rest junglinster sensor.physical_vienna_bedroom_humidity 60
    entity declare sensor.physical:netatmo:temperature
      import rest junglinster sensor.physical_vienna_bedroom_temperature 60
    entity declare sensor.infrastructural:netatmo:radio
      import rest junglinster sensor.infrastructural_vienna_bedroom_netatmo_radio 60
    entity declare binary_sensor.infrastructural:netatmo:node
      import rest junglinster sensor.infrastructural_vienna_bedroom_netatmo_reachability 60 "$ == 'True'"

    entity declare sensor.physical:frient:illuminance
    entity declare sensor.physical:frient:temperature
    entity declare binary_sensor.physical:frient:motion
    entity battery_level_device frient

    entity battery_level_device bed/moes 20
    entity battery_level_device bed/shortcut/left  20
    entity battery_level_device bed/shortcut/right 20
    entity battery_level_device door/moes/1 20
    entity battery_level_device door/moes/2 20
    entity battery_level_device hallway/door/moes/1 20
    entity battery_level_device hallway/door/moes/2 20
    
    entity declare binary_sensor.physical::door
    entity battery_level_device aqara_windoor 10

    begin space social:bed
      entity light_device left
      entity light_device right
    end space
    entity light_device main

    entity media_player sonos
    entity declare sensor.infrastructural:sonos:battery_level
    entity battery_alert sonos 10

    entity declare cover.social::
      open_stop_close
      provides device_node blinds

     light_on social:main
  end space 

  begin space social:shower_room
    entity declare sensor.infrastructural:netatmo:battery_level
      import rest junglinster sensor.infrastructural_vienna_shower_room_netatmo_battery_level 60
    entity battery_alert netatmo 20
    entity declare sensor.physical:netatmo:co2
      import rest junglinster sensor.physical_vienna_shower_room_netatmo_co2 60
    entity declare sensor.physical:netatmo:humidity
      import rest junglinster sensor.physical_vienna_shower_room_netatmo_humidity 60
    entity declare sensor.physical:netatmo:temperature
      import rest junglinster sensor.physical_vienna_shower_room_netatmo_temperature 60
    entity declare sensor.infrastructural:netatmo:radio
      import rest junglinster sensor.infrastructural_vienna_shower_room_netatmo_radio 60
    entity declare binary_sensor.infrastructural:netatmo:node
      import rest junglinster sensor.infrastructural_vienna_shower_room_netatmo_reachability 60 "$ == 'True'"

    entity declare sensor.physical:philips_motion:illuminance
    entity declare sensor.physical:philips_motion:temperature
    entity declare binary_sensor.physical:philips_motion:motion
    entity battery_level_device philips_motion 10

    entity declare binary_sensor.physical:aqara_water:water
    entity battery_level_device aqara_water

    entity declare sensor.physical:radiator/robb:temperature no_collect   
    entity power_switch social radiator robb 1
      icon mdi:heating-coil

    entity declare sensor.physical:washing_machine/robb:temperature no_collect   
    entity power_switch social washing_machine robb 1
      icon mdi:washing-machine

    entity light_device main
    entity light_device mirror

    entity battery_level_device door/moes/1 20
    entity battery_level_device door/moes/2 20
    entity battery_level_device mirror/moes 20
          
    light_on social:main
    lights_motion_guarded 15
  end space

  light_on social:living_room social:hallway
end space

begin space social:terrace
  entity declare sensor.infrastructural:netatmo_outdoor:battery_level
    import rest junglinster sensor.infrastructural_vienna_terrace_netatmo_outdoor_battery_level 60
  entity battery_alert netatmo_outdoor 20
  entity declare sensor.physical:netatmo_outdoor:humidity
    import rest junglinster sensor.physical_vienna_terrace_netatmo_outdoor_humidity 60
  entity declare sensor.physical:netatmo_outdoor:temperature
    import rest junglinster sensor.physical_vienna_terrace_netatmo_outdoor_temperature 60
  entity declare sensor.infrastructural:netatmo_outdoor:radio
    import rest junglinster sensor.infrastructural_vienna_terrace_netatmo_outdoor_radio 60  
  entity declare binary_sensor.infrastructural:netatmo_outdoor:node
    import rest junglinster sensor.infrastructural_vienna_terrace_netatmo_outdoor_reachability 60 "$ == 'True'"

  entity declare sensor.infrastructural:netatmo_windmeter:battery_level
    import rest junglinster sensor.infrastructural_vienna_terrace_netatmo_windmeter_battery_level 60
  entity battery_alert netatmo_windmeter 20
  entity declare sensor.social::wind_direction
    import rest junglinster sensor.physical_vienna_terrace_netatmo_windmeter_wind_direction 60
  entity declare sensor.social::wind_speed
    import rest junglinster sensor.physical_vienna_terrace_netatmo_windmeter_wind_speed 60
  entity declare sensor.infrastructural:netatmo_windmeter:radio
    import rest junglinster sensor.infrastructural_vienna_terrace_netatmo_windmeter_radio 60  
  entity declare binary_sensor.infrastructural:netatmo_windmeter:node
    import rest junglinster sensor.infrastructural_vienna_terrace_netatmo_windmeter_reachability 60 "$ == 'True'"

  windy social:wind_speed 00:01:00 00:10:00

  entity declare binary_sensor.social::daylight
    define satisfies sun.sun:/!elevation "$ > 4"
  
  entity light_device physical left
  entity light_device physical right

  entity declare sensor.physical:signify_motion:illuminance
    provides device_node signify_motion
  entity declare sensor.physical:signify_motion:temperature
  entity declare binary_sensor.physical:signify_motion:motion
  entity declare sensor.infrastructural:signify_motion:battery_level
  entity battery_alert signify_motion 20
  sunny physical:signify_motion:illuminance 00:05:00 00:05:00
end space

light_on social

entity declare sun.sun
