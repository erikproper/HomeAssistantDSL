LocalServer=vienna.fritz.box
JunglinsterServer=junglinster.fritz.box

if ServerIsUp $LocalServer; then
  MainInstance=http://vienna.fritz.box:8123
  JunglinsterInstance=https://junglinster.homelinux.org
elif ServerIsUp $JunglinsterServer; then
  MainInstance=https://vienna.homelinux.org
  JunglinsterInstance=https://junglinster.homelinux.org
else
  MainInstance=https://vienna.homelinux.org
  JunglinsterInstance=https://junglinster.homelinux.org
fi

