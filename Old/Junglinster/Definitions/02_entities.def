    entity battery_level_device philips_motion 10

    begin space social:entrance
      entity declare binary_sensor.physical:aqara_magnet:door
      entity battery_level_device aqara_magnet 10
    end space

    heating_leak binary_sensor.social:door

    light_on social:main
    lights_motion_guarded 10
    space_off @light
  end space

  begin space social:storage_room
    entity declare switch.physical::heating_raw        
    entity declare switch.physical::heating
      define flip switch.physical::heating_raw

    entity declare light.social:main

    entity declare switch.physical:backup
      icon mdi:server
      provides device_node backup_innr
    entity declare binary_sensor.infrastructural:backup:node

    entity declare sensor.infrastructural:backup:load
      define cli_sensor pi backup.fritz.box ./cpu/load
    entity declare sensor.infrastructural:backup:temperature no_collect
      define cli_sensor pi backup.fritz.box ./cpu/temperature

    entity declare binary_sensor.physical:windows/aqara_magnet:window
    entity battery_level_device windows/aqara_magnet 10
    
    entity declare sensor.physical:netatmo:co2
    entity declare sensor.physical:netatmo:humidity
    entity declare sensor.physical:netatmo:temperature
    entity declare sensor.infrastructural:netatmo:radio
    entity declare sensor.infrastructural:netatmo:reachability
    entity declare binary_sensor.infrastructural:netatmo:node
      define satisfies sensor.infrastructural:netatmo:reachability "$ == 'True'"
    entity declare sensor.infrastructural:netatmo:battery_level
    entity battery_alert netatmo 20

    entity declare sensor.physical:door/aqara_multi:humidity
    entity declare sensor.physical:door/aqara_multi:pressure
      define adjust 38 1
    entity declare sensor.physical:door/aqara_multi:temperature
    entity battery_level_device door/aqara_multi 15

    entity declare sensor.physical:philips_motion:temperature
    entity declare sensor.physical:philips_motion:illuminance
    entity declare binary_sensor.physical:philips_motion:motion
    entity battery_level_device philips_motion 10

    light_on social:main
    lights_motion_guarded 10
    space_off @light
  end space
  
  begin space social:bathroom
    entity declare switch.physical::heating_raw        
    entity declare switch.physical::heating
      define flip switch.physical::heating_raw

    entity declare light.physical:main_disc no_collect
    entity declare light.physical:main no_collect
      provides device_node /house/server_room/fuse_box/zwave/029
    entity declare light.social:main
      icon mdi:lightbulb
      define switched_device light.physical:main_disc light.physical:main

    entity declare switch.social:whirlpool
      provides device_node bathtub/relais_box
    entity declare binary_sensor.physical:whirlpool:motion
      define has_state switch.social:whirlpool on

    entity battery_level_device philips_dimmer 20

    entity declare binary_sensor.physical:windows/aqara_magnet:window
    entity battery_level_device windows/aqara_magnet 10

    entity declare sensor.physical:netatmo:co2
    entity declare sensor.physical:netatmo:humidity
    entity declare sensor.physical:netatmo:temperature
    entity declare sensor.infrastructural:netatmo:radio
    entity declare sensor.infrastructural:netatmo:reachability
    entity declare binary_sensor.infrastructural:netatmo:node
      define satisfies sensor.infrastructural:netatmo:reachability "$ == 'True'"
    entity declare sensor.infrastructural:netatmo:battery_level
    entity battery_alert netatmo 20

    entity declare sensor.physical:aqara_multi:humidity
    entity declare sensor.physical:aqara_multi:pressure
      define adjust 38 1
    entity declare sensor.physical:aqara_multi:temperature
    entity battery_level_device aqara_multi 15

    entity declare sensor.physical:right/philips_motion:temperature
    entity declare sensor.physical:right/philips_motion:illuminance
    entity declare binary_sensor.physical:right/philips_motion:motion
    entity battery_level_device right/philips_motion 10

    entity declare sensor.physical:left/philips_motion:temperature
    entity declare sensor.physical:left/philips_motion:illuminance
    entity declare binary_sensor.physical:left/philips_motion:motion
    entity battery_level_device left/philips_motion 10

    entity media_player sonos

    heating_leak binary_sensor.social:window
    light_on social:main
    lights_motion_guarded 10
    space_off @light @media switch.social:whirlpool
  end space

  begin space social:office
    entity declare switch.physical::heating_raw        
    entity declare switch.physical::heating
      define flip switch.physical::heating_raw

    entity declare binary_sensor.infrastructural:sonos_left:node
    entity declare binary_sensor.infrastructural:sonos_right:node

    entity declare sensor.physical:netatmo:co2
    entity declare sensor.physical:netatmo:humidity
    entity declare sensor.physical:netatmo:noise
    entity declare sensor.physical:netatmo:pressure
    entity declare sensor.physical:netatmo:temperature
    entity declare sensor.infrastructural:netatmo:radio
    entity declare sensor.infrastructural:netatmo:reachability
    entity declare binary_sensor.infrastructural:netatmo:node
      define satisfies sensor.infrastructural:netatmo:reachability "$ == 'True'"

    entity declare binary_sensor.infrastructural:orbi:node

    entity switch_device social desktop
    entity switch_device social media_drive
    entity switch_device social imac
    entity switch_device social photography
    entity switch_device social shredder
    entity switch_device social mini_fans
    entity switch_device social cycling
    entity switch_device social cycling_fans

    entity media_player sonos
    entity media_player apple_tv no_collect switch.social:cycling
    entity media_player tv       no_collect switch.social:cycling

    entity declare light.physical:ceiling no_collect
    entity declare light.physical:main no_collect
      provides device_node /house/server_room/fuse_box/zwave/023
    entity declare light.social:main
      icon mdi:lightbulb
      define switched_device light.physical:ceiling light.physical:main

    entity declare light.social:lower_strip
      provides device_node lower_strip
    entity declare light.social:upper_strip
      provides device_node upper_strip

    entity declare light.social:low_board
      provides device_node low_board

    follows light.social:low_board light.social:main

    entity declare sensor.physical:door/aqara_multi:humidity
    entity declare sensor.physical:door/aqara_multi:pressure
      define adjust 38 1
    entity declare sensor.physical:door/aqara_multi:temperature
    entity battery_level_device door/aqara_multi 15

    begin space social:drain
      entity declare binary_sensor.social:left/luminea:water
      entity battery_level_device left/luminea

      entity declare binary_sensor.social:right/luminea:water
      entity battery_level_device right/luminea
    end space

    entity declare binary_sensor.physical:windows/left/aqara_magnet:window
    entity battery_level_device windows/left/aqara_magnet 10

    entity declare binary_sensor.physical:windows/right/aqara_magnet:window
    entity battery_level_device windows/right/aqara_magnet 10

    light_on social:main
    heating_leak binary_sensor.social:window
    space_off switch.social:cycling switch.social:cycling_fans @light @media
  end space

  begin_virtual_space social:extension
    member social:/house/server_room
    member social:/house/corridor
    member social:/house/storage_room
    member social:/house/bathroom
    member social:/house/office
    light_on social:/house/corridor social:/house/office
    space_off @all
    space_on light.social::
  end_virtual_space

  begin_virtual_space social:laundry_corridor
    member social:/house/downward_hallway
    member social:/house/laundry_kitchen
    light_on @all
    space_off @all
    space_on light.social::
  end_virtual_space

  light_on social:upward_hallway
  space_off cover.social:/terrace/awnings @light @media
end space

begin space social:loft
  entity declare light.social:main
    provides device_node switch_box/nodon

  entity declare sensor.physical:aqara_multi:humidity
  entity declare sensor.physical:aqara_multi:pressure 
    define adjust 38 1
  entity declare sensor.physical:aqara_multi:temperature
  entity battery_level_device aqara_multi 15
end space

begin space social:cars
  begin space social:xc40
    entity declare binary_sensor.social:front/right:door
    entity declare binary_sensor.social:front/left:door
    entity declare binary_sensor.social:rear/right:door
    entity declare binary_sensor.social:rear/left:door
    entity declare binary_sensor.social:hood:door
    entity declare binary_sensor.social:tailgate:door
    entity declare binary_sensor.social:front/right:window
    entity declare binary_sensor.social:front/left:window
    entity declare binary_sensor.social:rear/right:window
    entity declare binary_sensor.social:rear/left:window
    entity declare binary_sensor.social:service:warning
    entity declare binary_sensor.social:brake_fluid:warning
    entity declare binary_sensor.social:washer_fluid:warning
    entity declare device_tracker.social::position
    entity declare lock.social:
    entity declare binary_sensor.social::engine
    entity declare sensor.social::odometer
    entity declare sensor.social::fuel/level
    entity declare sensor.social::fuel/consumption
    entity declare sensor.social::fuel/range
  end space
end space

entity declare sun.sun
entity declare binary_sensor.social::daylight
  define satisfies sun.sun!elevation "$ > 4"

space_off @light @media


