      provides device_node /house/server_room/fuse_box/zwave/021
    entity declare light.social:main
      icon mdi:lightbulb
      define switched_device light.physical:main_spots light.physical:main

    entity light_device social corb

    follows light.social:corb light.social:main
    follows light.social:corb light.physical:main
      
    entity declare sensor.physical:netatmo:co2
    entity declare sensor.physical:netatmo:humidity
    entity declare sensor.physical:netatmo:temperature
    entity declare sensor.infrastructural:netatmo:radio
    entity declare sensor.infrastructural:netatmo:reachability
