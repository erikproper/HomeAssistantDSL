entity declare sensor.social:power_total
  # Availability depends on binary_sensor.infrastructural:smarty:node
entity declare sensor.social:power_current
  # Availability depends on binary_sensor.infrastructural:smarty:node

begin space social:entrance
  entity declare sensor._:/ems_esp_boiler_boiler_outside_temperature
  entity declare sensor.physical:garage_door:temperature
    define value sensor._:/ems_esp_boiler_boiler_outside_temperature
  # Available if binary_sensor.infrastructural:/house/laundry_kitchen/ems:node is available.

  entity declare switch.social:sockets
    provides device_node /garage/fuse_box/zwave/028
  entity declare light.social:front_door
  entity declare light.social:carport
    provides device_node /house/server_room/zwave/027

  entity declare binary_sensor.social:front_door:ding
    provides device_node ring
  entity declare binary_sensor.social:front_door:motion
  entity declare sensor.social:front_door/ring:volume
  entity declare sensor.infrastructural:front_door/ring:battery_level
  entity battery_alert front_door/ring 20

  light_on social:front_door
  space_off @light
end space

begin space social:terrace
  begin space social:front
    entity declare sensor.physical:netatmo:humidity
    entity declare sensor.physical:netatmo:temperature
    entity declare sensor.infrastructural:netatmo:radio
    entity declare sensor.infrastructural:netatmo:reachability
    entity declare binary_sensor.infrastructural:netatmo:node
      define satisfies sensor.infrastructural:netatmo:reachability "$ == 'True'"
    entity declare sensor.infrastructural:netatmo:battery_level
    entity battery_alert netatmo 20

    entity declare light.social:main
      provides device_node /house/server_room/fuse_box/zwave/024

    space_off @light
  end space

  begin space social:garden
    entity declare sensor.physical:aqara_multi:humidity
    entity declare sensor.physical:aqara_multi:pressure 
    entity declare sensor.physical:aqara_multi:temperature
    entity battery_level_device aqara_multi 15

    entity declare light.social:main
      provides device_node /house/server_room/fuse_box/zwave/027

    space_off @light
  end space

  entity declare cover.social:awnings
    open_stop_close no_collect
    provides device_node /house/server_room/fuse_box/zwave/013

  entity declare light.social:rear

  entity declare switch.social:sockets
    provides device_node /house/server_room/fuse_box/zwave/025
    
  light_on social:rear
  space_off switch.social:sockets @light
end space

begin space social:garage
  entity declare binary_sensor.infrastructural:smarty:node
  entity declare sensor.infrastructural:smarty:load
    define cli_sensor pi smarty.fritz.box ./cpu/load
    # Availability depends on binary_sensor.infrastructural:smarty:node
  entity declare sensor.infrastructural:smarty:temperature no_collect
    define cli_sensor pi smarty.fritz.box ./cpu/temperature
    # Availability depends on binary_sensor.infrastructural:smarty:node
  entity declare switch.infrastructural:smarty
     provides device_node smarty/innr

  entity declare sensor.physical:rear/aqara_multi:humidity
  entity declare sensor.physical:rear/aqara_multi:pressure 
    define adjust 38 1
  entity declare sensor.physical:rear/aqara_multi:temperature
  entity battery_level_device rear/aqara_multi 15

  entity declare binary_sensor.physical:rear/ikea_motion:motion
    provides device_node rear/ikea_motion
  entity declare sensor.infrastructural:rear/ikea_motion:battery_level
  entity battery_alert rear/ikea_motion 10

  entity declare sensor.physical:front/aqara_multi:humidity
  entity declare sensor.physical:front/aqara_multi:pressure
    define adjust 38 1
  entity declare sensor.physical:front/aqara_multi:temperature
  entity battery_level_device front/aqara_multi 15

  entity declare binary_sensor.physical:front/ikea_motion:motion
    provides device_node front/ikea_motion
  entity declare sensor.infrastructural:front/ikea_motion:battery_level
  entity battery_alert front/ikea_motion 10

  entity declare binary_sensor.physical:garage_door/aqara_magnet:door
  entity battery_level_device garage_door/aqara_magnet 10

  entity declare light.social:main
    provides device_node /garage/fuse_box/zwave/019

  entity media_player sonos 

  entity thermostat radiator/aqara_thermostat
  entity battery_level radiator/aqara_thermostat 20

  heating_leak binary_sensor.social:door

  light_on social:main
  lights_motion_guarded 10
  space_off @light @media
end space

begin space social:house
  entity declare sensor.social:heating:power

  entity power_switch social rainwater_pump zigbee 10

  entity declare binary_sensor.social:reservoir:warning
    icon $WaterIcon

  begin space social:laundry_kitchen
    entity declare binary_sensor.infrastructural:ems:node
    
    entity declare light.social:main

    begin space social:rack
      entity declare sensor.infrastructural:junglinster:load
      entity declare sensor.infrastructural:junglinster:temperature no_collect
    end space

    entity declare sensor.physical:front/aqara_multi:humidity
    entity declare sensor.physical:front/aqara_multi:pressure
      define adjust 38 1
    entity declare sensor.physical:front/aqara_multi:temperature
    entity battery_level_device front/aqara_multi 15

    entity declare sensor.physical:rear/aqara_multi:humidity
    entity declare sensor.physical:rear/aqara_multi:pressure 
      define adjust 38 1
    entity declare sensor.physical:rear/aqara_multi:temperature
    entity battery_level_device rear/aqara_multi 15

    entity declare binary_sensor.physical:rear/frient:motion
    entity declare sensor.physical:rear/frient:illuminance
    entity declare binary_sensor.physical:rear/frient:vibration
    entity battery_level_device rear/frient

    entity declare binary_sensor.physical:front/frient:motion
    entity declare sensor.physical:front/frient:illuminance
    entity declare binary_sensor.physical:front/frient:vibration
    entity battery_level_device front/frient

    begin space social:laundry
      entity declare binary_sensor.physical:aqara_water:water
      entity battery_level_device aqara_water

      entity power_switch social washing robb/washing 10
      entity power_switch social drying  robb/drying  10
    end space

    begin space social:water_pump
      entity declare binary_sensor.physical:aqara_water:water
      entity battery_level_device aqara_water
    end space
    
    light_on social:main
    lights_motion_guarded 10
    space_off @light
  end space

  begin space social:living_room
    entity declare switch.social:tv
      provides device_node tv_switch

    entity media_player sonos no_play "TV"
    entity media_player tv switch.social:tv
    entity media_player apple_tv

    entity declare binary_sensor.infrastructural:sonos_playbar:node
    entity declare binary_sensor.infrastructural:sonos_subwoofer:node
    entity declare binary_sensor.infrastructural:sonos_surround_right:node
    entity declare binary_sensor.infrastructural:sonos_surround_left:node
    entity declare binary_sensor.infrastructural:orbi:node
    entity declare binary_sensor.infrastructural:connexoon:node
    entity declare binary_sensor.infrastructural:frame:node
    entity declare sensor.infrastructural:frame:load
      define cli_sensor pi 192.168.178.58 ./cpu/load
    entity declare sensor.infrastructural:frame:temperature no_collect
      define cli_sensor pi 192.168.178.58 ./cpu/temperature

    entity declare cover.social:front:
      open_stop_close
      provides device_node front/somfy
    entity declare number.social:front:my_position
    entity declare button.social:front:to_my_position
    entity declare button.infrastructural:front/somfy:identify

    entity declare cover.social:rear:
      open_stop_close
      provides device_node rear/somfy
    entity declare number.social:rear:my_position
    entity declare button.social:rear:to_my_position
    entity declare button.infrastructural:rear/somfy:identify

    entity thermostat front/radiator/aqara_thermostat
    entity battery_level front/radiator/aqara_thermostat 20
    
    entity thermostat rear/radiator/aqara_thermostat
    entity battery_level rear/radiator/aqara_thermostat 20

    entity declare sensor.physical:netatmo:co2
    entity declare sensor.physical:netatmo:humidity
    entity declare sensor.physical:netatmo:noise
    entity declare sensor.physical:netatmo:pressure
    entity declare sensor.physical:netatmo:temperature
    entity declare sensor.infrastructural:netatmo:radio
    entity declare sensor.infrastructural:netatmo:reachability
    entity declare binary_sensor.infrastructural:netatmo:node
      define satisfies sensor.infrastructural:netatmo:reachability "$ == 'True'"

    entity battery_level_device dining/philips_dimmer 20
    entity battery_level_device living/philips_dimmer 20

    entity light_device social indirect

    begin space social:living
      entity declare light.physical:main no_collect
        provides device_node hallway_door_switch_box/fibaro
      entity declare light.physical:main_dimmer no_collect
      entity declare light.social:main
        icon mdi:lightbulb
        define switched_device light.physical:main_dimmer light.physical:main

      entity light_device social hanging_sideboard
      entity light_device social bloom_left
      entity light_device social bloom_right
      entity light_device social christmas_tree
      entity light_device social gray_sideboard

      entity declare switch.social:picture_frame
        define cli_switch pi 192.168.178.58 ./bin/start_slideshow ./bin/stop_slideshow ./bin/check_slideshow

      entity declare binary_sensor.physical:windows/aqara_magnet:window
      entity battery_level_device windows/aqara_magnet 10

      light_on social:main
    end space

    begin space social:dining
      entity declare light.physical:main no_collect
      entity declare light.physical:main_dimmer no_collect
      entity declare light.social:main
        icon mdi:lightbulb
        define switched_device light.physical:main_dimmer light.physical:main

      entity declare light.social:red_highboard

      entity declare binary_sensor.physical:windows/aqara_magnet:window
      entity battery_level_device windows/aqara_magnet 10

      light_on social:main
    end space

    heating_leak binary_sensor.social::window

    light_on social:dining

    space_off @light @media
  end space

  begin space social:kitchen
    entity declare cover.social::
      open_stop_close
      provides device_node somfy
    entity declare number.social::my_position
    entity declare button.social::to_my_position
    entity declare button.infrastructural:somfy:identify

    entity power_switch social nespresso zigbee 10
    entity declare binary_sensor.social:nespresso:brews
        define satisfies sensor.social:nespresso:power "( $ | int(0) > 200 )"
    entity declare binary_sensor.social:nespresso:in_use
        define has_state binary_sensor.social:nespresso:brews "on" "" "00:10:00"

    entity media_player sonos
    entity declare sensor.infrastructural:sonos:battery_level
    entity battery_alert sonos 10

    entity declare sensor.physical:netatmo:co2
    entity declare sensor.physical:netatmo:humidity
    entity declare sensor.physical:netatmo:temperature
    entity declare sensor.infrastructural:netatmo:radio
    entity declare sensor.infrastructural:netatmo:reachability
    entity declare binary_sensor.infrastructural:netatmo:node
      define satisfies sensor.infrastructural:netatmo:reachability "$ == 'True'"
    entity declare sensor.infrastructural:netatmo:battery_level
    entity battery_alert netatmo 20

    entity thermostat radiator/aqara_thermostat
    entity battery_level radiator/aqara_thermostat 20

    entity light_device go
    entity light_device main

    begin space social:workplace
      entity declare sensor.physical:furnace:power
      entity declare binary_sensor.social:furnace:consumes
        define satisfies sensor.physical:furnace:power "( $ | int(0) > 50 )"
      entity declare switch.physical:furnace
      entity declare switch.social:furnace
        define flip switch.physical:furnace

      entity declare light.physical:: no_collect
      entity declare light.physical::dimmer no_collect
      entity declare light.social::main
        icon mdi:lightbulb
        define switched_device light.physical::dimmer light.physical::

      entity declare binary_sensor.physical:aqara_magnet:window
      entity battery_level_device aqara_magnet 10
    end space

    begin space social:terrace_door
      entity declare binary_sensor.physical:aqara_magnet:door
      entity battery_level_device aqara_magnet 10

      entity battery_level_device philips_dimmer 20
    end space

    light_on social:main
    heating_leak binary_sensor.social:terrace_door/door
    space_off @light @media
  end space

