list "Nodes" all binary_sensor.*:*:node
  clean_prefix  infrastructural
  clean_postfix node

list "Windoors" all binary_sensor.*:*:door binary_sensor.*:*:window
  clean_prefix  social
  clean_prefix  physical
  clean_prefix  apartment

list "Water" all binary_sensor.*:*:water
  clean_prefix  social
  clean_prefix  physical
  clean_prefix  apartment

list "Battery levels" all sensor.*:*:battery_level
  clean_prefix  infrastructural
  clean_postfix battery_level

list "Battery alerts" all binary_sensor.*:*:battery_alert
  clean_prefix  infrastructural
  clean_postfix battery_alert

list "Radios" all sensor.*:*:radio
  clean_prefix  infrastructural
  clean_postfix radio

list "Temperatures" all sensor.*:*:temperature
  clean_prefix  social
  clean_prefix  physical
  clean_prefix  infrastructural
  
list "Pressures" all sensor.*:*:pressure
  clean_prefix  social
  clean_prefix  physical
  clean_prefix  infrastructural

list "Thermostats" all climate.*
  clean_prefix  social
  clean_prefix  physical
  clean_postfix thermostat

list "Covers" all cover.*
  clean_prefix  social
  clean_prefix  physical
  clean_prefix  apartment

list "Ignore no motion" all input_boolean.*:*:no_motion/ignore
  clean_prefix  social
  clean_postfix no_motion.ignore

list "Ignore leakage" all input_boolean.*:*:heating/leakage/ignore
  clean_prefix  social
  clean_postfix heating.leakage.ignore
