function entity_zigbee_group { # $1 = Domain, $2 = Sphere, $3 = Location, $4 ... $n = Entity names 
  GroupDomain=$1
  GroupLocation=$3

  entity ${GroupDomain}_device $2 $GroupLocation

  begin space physical:$GroupLocation no_collect
    shift; shift; shift

    for e in $*; do
      entity ${GroupDomain}_device physical $e
    done

  end space
}